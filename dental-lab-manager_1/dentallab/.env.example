# ─────────────────────────────────────────────────────────────────────────────
# Dental Lab Manager — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE LOCALLY:
#   1. Copy this file:   cp .env.example .env.local
#   2. Fill in the values below
#   3. Run:              npm run dev
#
# NEVER commit .env.local to git — it contains secret keys.
#
# WHERE TO FIND THESE VALUES:
#   Supabase Dashboard → Your Project → Settings → API
#   ┌────────────────────────────────────────────────────────────┐
#   │  Project URL      → NEXT_PUBLIC_SUPABASE_URL              │
#   │  anon / public    → NEXT_PUBLIC_SUPABASE_ANON_KEY         │
#   │  service_role     → SUPABASE_SERVICE_ROLE_KEY             │
#   └────────────────────────────────────────────────────────────┘

# ── Supabase (required) ──────────────────────────────────────────────────────

# Your Supabase project URL, e.g. https://abcdefghijklm.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — server-side only, bypasses Row Level Security
# Add this to Vercel environment variables as well (mark as Secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App (optional) ───────────────────────────────────────────────────────────

# The URL where the app is hosted — used for auth redirects
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app  (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_APP_NAME="Dental Lab Manager"
NEXT_PUBLIC_CURRENCY=USD

# ── Supabase Auth setup (do this in the Supabase dashboard, not here) ────────
#
# Authentication → URL Configuration:
#   Site URL:       http://localhost:3000
#   Redirect URLs:  http://localhost:3000/api/auth/callback
#                   https://your-app.vercel.app/api/auth/callback   ← add for prod
#
# Authentication → Settings:
#   • For local dev: turn "Confirm email" OFF for instant login
#   • For production: turn "Confirm email" ON
